<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Vista TV — SistemaCapacita</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    :root {
      --rojo:#C0392B; --rojo2:#E74C3C;
      --gris:#0e0e0e; --gris2:#1a1a1a; --gris3:#242424; --gris4:#2e2e2e;
      --blanco:#F0EFEB; --texto:#777;
      --verde:#27AE60; --verde2:#2ecc71;
      --amarillo:#F39C12;
    }

    html, body {
      width:100%; height:100%;
      background:var(--gris);
      font-family:'Barlow',sans-serif;
      color:var(--blanco);
      overflow:hidden;
    }

    /* ── HEADER ── */
    .header {
      height:90px;
      background:var(--gris2);
      border-bottom:2px solid var(--rojo);
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:0 48px;
      flex-shrink:0;
    }

    .header-logo {
      display:flex;
      align-items:center;
      gap:16px;
    }

    .logo-icon {
      width:48px; height:48px;
      background:var(--rojo);
      display:flex; align-items:center; justify-content:center;
    }

    .logo-icon svg { width:26px; height:26px; fill:white; }

    .logo-text {
      font-family:'Barlow Condensed',sans-serif;
      font-size:22px;
      font-weight:700;
      letter-spacing:2px;
      text-transform:uppercase;
      line-height:1.2;
    }

    .logo-text span {
      display:block;
      font-size:11px;
      font-weight:400;
      color:var(--texto);
      letter-spacing:3px;
      margin-top:2px;
    }

    .header-center {
      font-family:'Barlow Condensed',sans-serif;
      font-size:15px;
      font-weight:600;
      letter-spacing:3px;
      text-transform:uppercase;
      color:var(--texto);
    }

    .header-clock {
      text-align:right;
    }

    .clock-time {
      font-family:'Barlow Condensed',sans-serif;
      font-size:40px;
      font-weight:700;
      line-height:1;
      color:var(--blanco);
      letter-spacing:2px;
    }

    .clock-date {
      font-size:12px;
      color:var(--texto);
      letter-spacing:1px;
      margin-top:4px;
      text-transform:capitalize;
    }

    /* ── CARRUSEL ── */
    .carrusel-wrap {
      height: calc(100vh - 90px);
      display:flex;
      flex-direction:column;
      justify-content:center;
      padding:32px 48px;
      position:relative;
      overflow:hidden;
    }

    .carrusel-track {
      display:flex;
      gap:24px;
      transition:transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
      will-change:transform;
    }

    /* ── TARJETA ── */
    .emp-card {
      background:var(--gris2);
      border:1px solid rgba(255,255,255,0.06);
      border-top:3px solid var(--rojo);
      flex-shrink:0;
      display:flex;
      flex-direction:column;
      overflow:hidden;
      transition:opacity 0.5s, transform 0.5s;
    }

    .card-top {
      padding:28px 28px 20px;
      display:flex;
      align-items:center;
      gap:20px;
      border-bottom:1px solid rgba(255,255,255,0.06);
    }

    .emp-foto {
      width:80px; height:80px;
      object-fit:cover;
      flex-shrink:0;
      border:2px solid rgba(255,255,255,0.08);
    }

    .emp-foto-placeholder {
      width:80px; height:80px;
      background:var(--rojo);
      display:flex; align-items:center; justify-content:center;
      font-family:'Barlow Condensed',sans-serif;
      font-size:32px; font-weight:700; color:white;
      flex-shrink:0;
    }

    .emp-info { flex:1; min-width:0; }

    .emp-nombre {
      font-family:'Barlow Condensed',sans-serif;
      font-size:28px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:1px;
      line-height:1.1;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .emp-legajo {
      font-size:12px;
      color:var(--texto);
      margin-top:5px;
      letter-spacing:2px;
      text-transform:uppercase;
    }

    .card-section {
      padding:16px 28px;
      border-bottom:1px solid rgba(255,255,255,0.04);
    }

    .card-section:last-child { border-bottom:none; }

    .section-label {
      font-size:9px;
      font-weight:700;
      color:var(--texto);
      letter-spacing:3px;
      text-transform:uppercase;
      margin-bottom:10px;
    }

    .apt-tags {
      display:flex;
      flex-wrap:wrap;
      gap:6px;
    }

    .apt-tag {
      background:rgba(192,57,43,0.12);
      border:1px solid rgba(192,57,43,0.25);
      color:var(--rojo2);
      font-size:12px;
      font-weight:600;
      padding:4px 12px;
      letter-spacing:0.5px;
      font-family:'Barlow Condensed',sans-serif;
      text-transform:uppercase;
    }

    .apt-empty {
      font-size:12px;
      color:var(--texto);
      font-style:italic;
    }

    .carnets-list {
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    .carnet-item {
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:6px 10px;
      background:rgba(255,255,255,0.03);
      border:1px solid rgba(255,255,255,0.06);
    }

    .carnet-especialidad {
      font-size:13px;
      font-weight:600;
      color:var(--blanco);
    }

    .carnet-vence {
      font-size:11px;
      color:var(--texto);
    }

    .badge-vigente {
      font-family:'Barlow Condensed',sans-serif;
      font-size:10px;
      font-weight:700;
      letter-spacing:1px;
      padding:2px 8px;
      background:rgba(39,174,96,0.12);
      border:1px solid rgba(39,174,96,0.25);
      color:var(--verde2);
    }

    .badge-proximo {
      font-family:'Barlow Condensed',sans-serif;
      font-size:10px;
      font-weight:700;
      letter-spacing:1px;
      padding:2px 8px;
      background:rgba(243,156,18,0.12);
      border:1px solid rgba(243,156,18,0.25);
      color:var(--amarillo);
    }

    .no-carnets {
      font-size:12px;
      color:var(--texto);
      font-style:italic;
    }

    /* ── PAGINACIÓN ── */
    .dots {
      display:flex;
      justify-content:center;
      gap:8px;
      margin-top:24px;
      flex-shrink:0;
    }

    .dot {
      width:8px; height:8px;
      border-radius:50%;
      background:rgba(255,255,255,0.15);
      transition:background 0.3s, transform 0.3s;
    }

    .dot.active {
      background:var(--rojo);
      transform:scale(1.3);
    }

    /* ── PANTALLA VACÍA ── */
    .empty-tv {
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      height:100%;
      gap:16px;
      color:var(--texto);
    }

    .empty-tv svg {
      width:64px; height:64px;
      stroke:var(--texto);
      fill:none;
      stroke-width:1;
    }

    .empty-tv h2 {
      font-family:'Barlow Condensed',sans-serif;
      font-size:28px;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:2px;
    }
  </style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-logo">
    <div class="logo-icon">
      <svg viewBox="0 0 24 24"><path d="M12 2L2 7v10l10 5 10-5V7L12 2zm0 2.18L20 8.5v7L12 19.82 4 15.5v-7L12 4.18z"/></svg>
    </div>
    <div class="logo-text">
      SistemaCapacita
      <span>Durlock · La Pampa</span>
    </div>
  </div>

  <div class="header-center">Personal Habilitado</div>

  <div class="header-clock">
    <div class="clock-time" id="clock-time">--:--</div>
    <div class="clock-date" id="clock-date">cargando...</div>
  </div>
</div>

<!-- CARRUSEL -->
<div class="carrusel-wrap">
  <% if (empleados.length === 0) { %>
  <div class="empty-tv">
    <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    <h2>Sin empleados registrados</h2>
  </div>
  <% } else { %>

  <div class="carrusel-track" id="track">
    <% empleados.forEach(emp => { %>
    <div class="emp-card" id="card-template" style="width:<%= cardWidth %>px">

      <div class="card-top">
        <% if (emp.foto) { %>
          <img src="/uploads/<%= emp.foto %>" class="emp-foto" alt="<%= emp.nombre %>"/>
        <% } else { %>
          <div class="emp-foto-placeholder"><%= emp.nombre.charAt(0) %><%= emp.apellido.charAt(0) %></div>
        <% } %>
        <div class="emp-info">
          <div class="emp-nombre"><%= emp.apellido %>,<br/><%= emp.nombre %></div>
          <div class="emp-legajo">Legajo #<%= emp.legajo %></div>
        </div>
      </div>

      <% if (emp.aptitudes) { %>
      <div class="card-section">
        <div class="section-label">Aptitudes</div>
        <div class="apt-tags">
          <% emp.aptitudes.split(', ').forEach(apt => { %>
            <span class="apt-tag"><%= apt %></span>
          <% }) %>
        </div>
      </div>
      <% } %>

      <div class="card-section">
        <div class="section-label">Carnets</div>
        <% if (emp.carnets && emp.carnets.length > 0) { %>
        <div class="carnets-list">
          <% emp.carnets.forEach(c => { %>
          <div class="carnet-item">
            <div>
              <div class="carnet-especialidad"><%= c.especialidad %></div>
              <div class="carnet-vence">Vence: <%= c.fecha_vencimiento_str %></div>
            </div>
            <span class="badge-<%= c.estado %>"><%= c.estado === 'vigente' ? 'Vigente' : 'Próximo' %></span>
          </div>
          <% }) %>
        </div>
        <% } else { %>
          <span class="no-carnets">Sin carnets registrados</span>
        <% } %>
      </div>

    </div>
    <% }) %>
  </div>

  <div class="dots" id="dots"></div>

  <% } %>
</div>

<script>
  // ── RELOJ ──
  function actualizarReloj() {
    const ahora = new Date();
    const h = String(ahora.getHours()).padStart(2,'0');
    const m = String(ahora.getMinutes()).padStart(2,'0');
    document.getElementById('clock-time').textContent = h + ':' + m;

    const fecha = ahora.toLocaleDateString('es-AR', {
      weekday:'long', day:'numeric', month:'long', year:'numeric'
    });
    document.getElementById('clock-date').textContent = fecha;
  }
  actualizarReloj();
  setInterval(actualizarReloj, 1000);

  // ── CARRUSEL ──
  const empleados = <%- JSON.stringify(empleados) %>;
  const VISIBLE = <%= visibleCards %>;
  const INTERVALO = 5000; // ms por tarjeta

  if (empleados.length > 0) {
    const track = document.getElementById('track');
    const dotsEl = document.getElementById('dots');
    const cards = track.querySelectorAll('.emp-card');
    const total = cards.length;
    let current = 0;
    let timer;

    // Crear dots
    for (let i = 0; i < total; i++) {
      const d = document.createElement('div');
      d.className = 'dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goTo(i));
      dotsEl.appendChild(d);
    }

    function goTo(idx) {
      current = idx;
      const cardWidth = cards[0].offsetWidth + 24; // width + gap
      const maxOffset = (total - VISIBLE) * cardWidth;
      let offset = idx * cardWidth;
      if (offset > maxOffset) offset = maxOffset;
      track.style.transform = `translateX(-${offset}px)`;

      dotsEl.querySelectorAll('.dot').forEach((d, i) => {
        d.classList.toggle('active', i === idx);
      });
    }

    function siguiente() {
      const next = (current + 1) % total;
      goTo(next);
    }

    function iniciarTimer() {
      timer = setInterval(siguiente, INTERVALO);
    }

    iniciarTimer();

    // Pausar al hover
    track.addEventListener('mouseenter', () => clearInterval(timer));
    track.addEventListener('mouseleave', iniciarTimer);
  }
</script>

</body>
</html>
